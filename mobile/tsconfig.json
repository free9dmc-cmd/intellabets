{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "lib": ["ES2022"],
    "allowJs": true,
    "paths": {
      "@intellabets/types": ["../packages/types/src"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "app/**/*"],
  "exclude": ["node_modules"]
}
