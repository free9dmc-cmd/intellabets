# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/intellabets"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Anthropic AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── RevenueCat (iOS/Android IAP) ────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET="your-revenuecat-webhook-secret"
NEXT_PUBLIC_REVENUECAT_IOS_KEY="appl_..."
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY="goog_..."

# ─── Sportsbook / Odds APIs ──────────────────────────────────────────────────
THE_ODDS_API_KEY="..."          # theoddsapi.com — live odds data
DRAFTKINGS_API_KEY="..."
FANDUEL_API_KEY="..."

# ─── Encryption (for sportsbook auth token storage) ──────────────────────────
ENCRYPTION_KEY="32-byte-hex-key-openssl-rand-hex-32"
ENCRYPTION_IV="16-byte-hex-iv-openssl-rand-hex-16"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
ADMIN_WEB_URL="http://localhost:3001"
PLATFORM_FEE_PERCENT="20"
ADMIN_EMAILS="admin@intellabets.com"

# ─── Push Notifications (real-time odds / pick alerts) ───────────────────────
PUSHER_APP_ID="..."
PUSHER_KEY="..."
PUSHER_SECRET="..."
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="..."
NEXT_PUBLIC_PUSHER_CLUSTER="us2"
