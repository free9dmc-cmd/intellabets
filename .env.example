# Database — use PostgreSQL in production (e.g. Supabase, Neon, Railway)
DATABASE_URL="file:./dev.db"

# NextAuth — generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Anthropic AI (powers AI picks via claude-sonnet-4-6)
ANTHROPIC_API_KEY="sk-ant-..."

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Platform settings
PLATFORM_FEE_PERCENT="20"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin panel — comma-separated emails that can access /admin
ADMIN_EMAILS="you@yourdomain.com"

# Mobile — set to your production Vercel URL for Capacitor builds
CAPACITOR_SERVER_URL="https://intellabets.vercel.app"
